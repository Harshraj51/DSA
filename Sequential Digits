class Solution {
public:
    vector<int> sequentialDigits(int low, int high) {
        string s = "123456789";
        vector<int> ans;

        for (int length = 2; length <= 9; length++) {
            for (int i = 0; i + length <= 9; i++) {
                int num = stoi(s.substr(i, length));

                if (num >= low && num <= high)
                    ans.push_back(num);
            }
        }

        return ans;
    }
};
